# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ═══════════════════════════════════════════════════════════════════
# SOLANA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Network: devnet or mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC Endpoint (Devnet by default)
NEXT_PUBLIC_SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Terminus Smart Contract Program ID (Devnet)
NEXT_PUBLIC_TERMINUS_PROGRAM_ID=EYjKKn4Qhjv2d2fE9yggedBdLJBPHiumwfbVLtofMMsb

# AI Oracle Public Key (used for challenge initiation)
# Get this from: solana-keygen pubkey /path/to/oracle_keypair.json
NEXT_PUBLIC_AI_ORACLE_PUBKEY=REPLACE_WITH_ACTUAL_ORACLE_PUBKEY

# ═══════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Backend API URL (for vault caching and OCR verification)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════
# STORAGE CONFIGURATION (Pinata/IPFS)
# ═══════════════════════════════════════════════════════════════════

# PINATA_API_KEY=your-pinata-api-key
# PINATA_SECRET_API_KEY=your-pinata-secret-api-key
# NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud

# ═══════════════════════════════════════════════════════════════════
# LIT PROTOCOL (Encryption/Access Control)
# ═══════════════════════════════════════════════════════════════════

# LIT_SOLANA_RPC=https://api.devnet.solana.com
# LIT_CHAIN=solana-devnet

# ═══════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════

# 1. NEVER commit .env.local to git
# 2. Use .env.local for local development
# 3. Use .env.production for production builds
# 4. Keep ORACLE_KEYPAIR_PATH (backend only) out of frontend env vars
